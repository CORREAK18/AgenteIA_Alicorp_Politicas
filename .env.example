# Servidor local
HOST=0.0.0.0
PORT=8000

# Proveedor de IA
LLM_PROVIDER=cohere
EMBEDDINGS_PROVIDER=cohere

# Cohere: obligatorio cuando se selecciona cohere
COHERE_API_KEY=
COHERE_CHAT_MODEL=command-a-03-2025
COHERE_EMBEDDING_MODEL=embed-v4.0
COHERE_TIMEOUT_SECONDS=120

# Gemini: completar solamente cuando se selecciona gemini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-exp-03-07

# Documentos e indice FAISS
PDF_DIR=./Documentos
FAISS_INDEX_DIR=./faiss_indexv2
HF_TOKENIZER_MODEL=BAAI/bge-m3
TAMANO_LOTE_EMBEDDINGS=20
PAUSA_SEGUNDOS_EMBEDDINGS=15
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
MOSTRAR_MULTIQUERIES=false

# Correo de tickets
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
TICKET_DESTINO=
SMTP_TIMEOUT_SECONDS=30
